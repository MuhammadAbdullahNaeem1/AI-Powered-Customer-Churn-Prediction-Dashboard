# Kaggle API credentials (get from https://www.kaggle.com/settings -> Create New Token)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key

# Database
DATABASE_URL=sqlite:///./churn.db

# Model artifact location (relative to backend/)
MODEL_PATH=ml/model.pkl

# CORS origin for the Next.js frontend
FRONTEND_ORIGIN=http://localhost:3000
